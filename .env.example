# =============================
# Banco de Dados
# =============================
DATABASE_URL=postgresql+asyncpg://lente:lente_dev@localhost:5432/lente
POSTGRES_USER=lente
POSTGRES_PASSWORD=lente_dev
POSTGRES_DB=lente

# =============================
# Google Cloud / Gemini
# =============================
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# Endpoint para geração (Gemini 3.1 preview é servido só em 'global').
GCP_LOCATION_GENERATE=global
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
# Matryoshka-truncado para caber no HNSW do pgvector (limite 2000 dims).
GEMINI_EMBEDDING_DIMENSIONS=1536

# =============================
# RAG
# =============================
# Similaridade cosseno mínima para um documento entrar no prompt (0-1).
RAG_LIMIAR_SIMILARIDADE=0.5
# Rate limit do /chat (formato slowapi).
RATE_LIMIT_CHAT=20/minute

# =============================
# PNCP
# =============================
PNCP_BASE_URL=https://pncp.gov.br/api/consulta/v1
PNCP_CNPJ_JEQUIE=13894878000160

# =============================
# Aplicação
# =============================
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production
APP_HOST=0.0.0.0
APP_PORT=8000

# =============================
# Frontend
# =============================
VITE_API_URL=http://localhost:8000
